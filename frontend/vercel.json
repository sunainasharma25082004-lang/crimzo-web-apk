{
  "headers": [
    {
      "source": "/crmizo.apk",
      "headers": [
        { "key": "Content-Type", "value": "application/vnd.android.package-archive" },
        { "key": "Content-Disposition", "value": "attachment; filename=\"crmizo.apk\"" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!crmizo\\.apk$).*)", "destination": "/index.html" }
  ]
}